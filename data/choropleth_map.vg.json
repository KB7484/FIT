\f0\fs24 \cf0 \{\
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",\
  "title": \{\
    "text": "Boutique Booming: Independent Breweries per 100k Residents (2026)",\
    "fontSize": 16,\
    "font": "Sans-Serif",\
    "anchor": "start"\
  \},\
  "width": 700,\
  "height": 500,\
  "projection": \{\
    "type": "mercator"\
  \},\
  "data": \{\
    "url": "data/states.geojson",\
    "format": \{\
      "type": "json",\
      "property": "features"\
    \}\
  \},\
  "transform": [\
    \{\
      "lookup": "properties.STATE_NAME",\
      "from": \{\
        "data": \{\
          "url": "data/brewery_density_by_state.csv"\
        \},\
        "key": "state",\
        "fields": ["brewery_count", "state_population_2025", "major_style_preference"]\
      \}\
    \},\
    \{\
      "calculate": "(datum.brewery_count / datum.state_population_2025) * 100000",\
      "as": "breweries_per_100k"\
    \}\
  ],\
  "mark": \{\
    "type": "geoshape",\
    "stroke": "#ffffff",\
    "strokeWidth": 1\
  \},\
  "encoding": \{\
    "color": \{\
      "field": "breweries_per_100k",\
      "type": "quantitative",\
      "title": "Breweries per 100k",\
      "scale": \{\
        "type": "linear",\
        "scheme": "oranges"\
      \}\
    \},\
    "tooltip": [\
      \{\
        "field": "properties.STATE_NAME",\
        "type": "nominal",\
        "title": "State"\
      \},\
      \{\
        "field": "brewery_count",\
        "type": "quantitative",\
        "title": "Total Craft Breweries"\
      \},\
      \{\
        "field": "breweries_per_100k",\
        "type": "quantitative",\
        "title": "Per 100k Residents",\
        "format": ".2f"\
      \},\
      \{\
        "field": "major_style_preference",\
        "type": "nominal",\
        "title": "Top Style Choice"\
      \}\
    ]\
  \}\
\}}